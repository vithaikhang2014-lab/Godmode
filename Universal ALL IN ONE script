-- Hàm tạo nút
local function createNiceButton(name, text, icon, color)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(1, -10, 0, 36)
    btn.BackgroundColor3 = color
    btn.BackgroundTransparency = 0.15
    btn.Text = icon .. " " .. text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.Parent = scrollFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundTransparency = 0
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundTransparency = 0.15
    end)
    
    return btn
end

-- ========== BIẾN TOÀN CỤC ==========
local godmode = false
local noclip = false
local fly = false
local flySpeed = 60
local expanded = true

-- ========== GODMODE FIXED ==========
local godmodeBtn = createNiceButton("Godmode", "GODMODE", "🛡️", Color3.fromRGB(80, 40, 40))
local godmodeConnections = {} -- Chứa tất cả connection để dễ quản lý
local godmodeActive = false

-- Hàm dọn dẹp tất cả connection cũ
local function cleanupGodmodeConnections()
    for _, conn in pairs(godmodeConnections) do
        if conn then
            pcall(function() conn:Disconnect() end)
        end
    end
    godmodeConnections = {}
end

-- Hàm bảo vệ nhân vật (chính)
local function protectCharacter(character)
    if not character or not godmodeActive then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local maxHealth = humanoid.MaxHealth
    
    -- Đặt máu về max ngay lập tức
    humanoid.Health = maxHealth
    
    -- 1. Bảo vệ khi máu thay đổi
    local healthConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if godmodeActive and humanoid and humanoid.Parent then
            if humanoid.Health ~= maxHealth then
                humanoid.Health = maxHealth
            end
        end
    end)
    table.insert(godmodeConnections, healthConn)
    
    -- 2. Chống chết (kiểm tra mỗi frame)
    local heartbeatConn = game:GetService("RunService").Heartbeat:Connect(function()
        if godmodeActive and humanoid and humanoid.Parent then
            if humanoid.Health <= 0 or humanoid.Health ~= maxHealth then
                humanoid.Health = maxHealth
            end
            -- Ngăn trạng thái chết
            if humanoid:GetState() == Enum.HumanoidStateType.Dead then
                humanoid.Health = maxHealth
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
    end)
    table.insert(godmodeConnections, heartbeatConn)
    
    -- 3. Chống đổi trạng thái chết
    local stateConn = humanoid.StateChanged:Connect(function(oldState, newState)
        if godmodeActive and humanoid and humanoid.Parent then
            if newState == Enum.HumanoidStateType.Dead then
                humanoid.Health = maxHealth
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
            -- Chống ragdoll
            if newState == Enum.HumanoidStateType.Ragdoll then
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
    end)
    table.insert(godmodeConnections, stateConn)
    
    -- 4. Chống break joints
    local breakConn = humanoid.BreakJointsOnDeath:GetPropertyChangedSignal("Value"):Connect(function()
        if godmodeActive then
            humanoid.BreakJointsOnDeath = false
        end
    end)
    table.insert(godmodeConnections, breakConn)
end

-- Bật Godmode
local function enableGodmode()
    if godmodeActive then return end
    
    godmode = true
    godmodeActive = true
    
    -- Dọn dẹp connection cũ
    cleanupGodmodeConnections()
    
    -- Bảo vệ nhân vật hiện tại
    local character = player.Character
    if character then
        protectCharacter(character)
    end
    
    -- Cập nhật UI
    godmodeBtn.Text = "🛡️ GODMODE ON"
    godmodeBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
    
    print("✅ GODMODE ĐÃ BẬT - Bạn bất tử!")
end

-- Tắt Godmode
local function disableGodmode()
    if not godmodeActive then return end
    
    godmode = false
    godmodeActive = false
    
    -- Xóa tất cả connection
    cleanupGodmodeConnections()
    
    -- Khôi phục máu bình thường (không can thiệp nữa)
    local character = player.Character
    local humanoid = character and character:FindFirstChild("Humanoid")
    if humanoid and humanoid.Health <= 0 then
        humanoid.Health = 100 -- Hồi sinh 1 tí nếu đang chết
    end
    
    -- Cập nhật UI
    godmodeBtn.Text = "🛡️ GODMODE OFF"
    godmodeBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 40)
    
    print("❌ GODMODE ĐÃ TẮT")
end

-- Xử lý bấm nút
godmodeBtn.MouseButton1Click:Connect(function()
    if godmodeActive then
        disableGodmode()
    else
        enableGodmode()
    end
end)

-- ========== CÁC CHỨC NĂNG KHÁC ==========

local function getHumanoid()
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        return player.Character.Humanoid
    end
    return nil
end

-- 2. NOCLIP
local noclipBtn = createNiceButton("Noclip", "NOCLIP", "🚪", Color3.fromRGB(40, 40, 80))
local noclipConn = nil

local function noclipFunc()
    if not noclip or not player.Character then return end
    for _, part in pairs(player.Character:GetDescendants()) do
        if part:IsA("BasePart") and part.CanCollide then
            part.CanCollide = false
        end
    end
end

local function disableNoclip()
    if not noclip then return end
    noclip = false
    if noclipConn then noclipConn:Disconnect() noclipConn = nil end
    if player.Character then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
    noclipBtn.Text = "🚪 NOCLIP OFF"
    noclipBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 80)
end

local function enableNoclip()
    if noclip then return end
    noclip = true
    if noclipConn then noclipConn:Disconnect() end
    noclipConn = game:GetService("RunService").Stepped:Connect(noclipFunc)
    noclipBtn.Text = "🚪 NOCLIP ON"
    noclipBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
end

noclipBtn.MouseButton1Click:Connect(function()
    if noclip then disableNoclip() else enableNoclip() end
end)

-- 3. FLY
local flyBtn = createNiceButton("Fly", "FLY", "✈️", Color3.fromRGB(40, 80, 40))
local flyBodyVel, flyBodyGyro, flyConn

local function disableFly()
    if not fly then return end
    fly = false
    if flyBodyVel then flyBodyVel:Destroy() flyBodyVel = nil end
    if flyBodyGyro then flyBodyGyro:Destroy() flyBodyGyro = nil end
    if flyConn then flyConn:Disconnect() flyConn = nil end
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.PlatformStand = false
    end
    flyBtn.Text = "✈️ FLY OFF"
    flyBtn.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
end

local function enableFly()
    if fly then return end
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    fly = true
    local hrp = char.HumanoidRootPart
    if char.Humanoid then char.Humanoid.PlatformStand = true end
    
    flyBodyVel = Instance.new("BodyVelocity")
    flyBodyVel.MaxForce = Vector3.new(1, 1, 1) * 100000
    flyBodyVel.Velocity = Vector3.new(0, 0, 0)
    flyBodyVel.Parent = hrp
    
    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(1, 1, 1) * 100000
    flyBodyGyro.CFrame = hrp.CFrame
    flyBodyGyro.Parent = hrp
    
    local uis = game:GetService("UserInputService")
    local run = game:GetService("RunService")
    
    flyConn = run.Heartbeat:Connect(function()
        if not fly or not hrp or not hrp.Parent then return end
        local cam = workspace.CurrentCamera
        local move = Vector3.new(0, 0, 0)
        if uis:IsKeyDown(Enum.KeyCode.W) then move = move + cam.CFrame.LookVector end
        if uis:IsKeyDown(Enum.KeyCode.S) then move = move - cam.CFrame.LookVector end
        if uis:IsKeyDown(Enum.KeyCode.A) then move = move - cam.CFrame.RightVector end
        if uis:IsKeyDown(Enum.KeyCode.D) then move = move + cam.CFrame.RightVector end
        if uis:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
        if uis:IsKeyDown(Enum.KeyCode.LeftControl) then move = move - Vector3.new(0, 1, 0) end
        if move.Magnitude > 0 then move = move.Unit * flySpeed end
        flyBodyVel.Velocity = move
        flyBodyGyro.CFrame = cam.CFrame
    end)
    
    flyBtn.Text = "✈️ FLY ON"
    flyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
end

flyBtn.MouseButton1Click:Connect(function()
    if fly then disableFly() else enableFly() end
end)

