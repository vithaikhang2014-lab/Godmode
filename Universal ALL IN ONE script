-- Xử lý respawn
player.CharacterAdded:Connect(function(character)
    currentHumanoid = character:FindFirstChild("Humanoid")
    
    -- Tự động bật lại godmode nếu đang bật
    if godmode then
        task.wait(0.1)
        enableGodmode()
    end
    
    -- Tự động bật lại noclip nếu đang bật
    if noclip then
        task.wait(0.1)
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = game:GetService("RunService").Stepped:Connect(noclipFunc)
    end
    
    -- Tắt fly khi respawn
    if fly then
        disableFly()
    end
end)

