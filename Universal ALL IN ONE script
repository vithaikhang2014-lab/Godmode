-- ========== 5. TP ON CLICK (ON/OFF) ==========
local tpBtn = createButton("TPClick", "TP ON CLICK", "📍", Color3.fromRGB(80, 40, 80))

local function enableTPClick()
    tpOnClick = true
    tpBtn.Text = "📍 TP ON CLICK ON"
    tpBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
end

local function disableTPClick()
    tpOnClick = false
    tpBtn.Text = "📍 TP ON CLICK OFF"
    tpBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 80)
end

local mouse = player:GetMouse()
mouse.Button1Down:Connect(function()
    if tpOnClick then
        -- Kiểm tra nếu chuột không ở trên GUI
        local target = mouse.Target
        local isOnGui = false
        local current = target
        while current do
            if current:IsA("GuiObject") and current:FindFirstAncestor("SuperGUI") then
                isOnGui = true
                break
            end
            current = current.Parent
        end
        
        if not isOnGui then
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and mouse.Hit then
                hrp.CFrame = CFrame.new(mouse.Hit.Position) + Vector3.new(0, 3, 0)
            end
        end
    end
end)

tpBtn.MouseButton1Click:Connect(function()
    if tpOnClick then disableTPClick() else enableTPClick() end
end)

