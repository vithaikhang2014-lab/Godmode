-- Tạo ScreenGui
local player = game:GetService("Players").LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "GodModeGUI"
gui.Parent = player:WaitForChild("PlayerGui")

-- Tạo khung chính
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 180, 0, 90)
frame.Position = UDim2.new(0.5, -90, 0.5, -45)
frame.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
frame.BackgroundTransparency = 0.15
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = gui

-- Bo góc cho khung
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = frame

-- Tiêu đề
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 25)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "✨ GOD MODE ✨"
title.TextColor3 = Color3.fromRGB(255, 215, 0)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.Parent = frame

-- Nút bật/tắt Godmode
local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 120, 0, 35)
toggleButton.Position = UDim2.new(0.5, -60, 0.5, -10)
toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
toggleButton.Text = "🔴 GOD MODE OFF"
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.Font = Enum.Font.GothamSemibold
toggleButton.TextSize = 12
toggleButton.BorderSizePixel = 0
toggleButton.Parent = frame

-- Bo góc cho nút
local buttonCorner = Instance.new("UICorner")
buttonCorner.CornerRadius = UDim.new(0, 5)
buttonCorner.Parent = toggleButton

-- Biến trạng thái
local godmode = false
local currentHumanoid = nil
local healthConnection = nil
local heartbeatConnection = nil
local stateConnection = nil

-- Hàm lấy Humanoid
local function getHumanoid()
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        return player.Character.Humanoid
    end
    return nil
end

-- Hàm cập nhật UI
local function updateUI()
    if godmode then
        toggleButton.Text = "🟢 GOD MODE ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        title.Text = "✨ GOD MODE: ACTIVE ✨"
        title.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        toggleButton.Text = "🔴 GOD MODE OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        title.Text = "✨ GOD MODE ✨"
        title.TextColor3 = Color3.fromRGB(255, 215, 0)
    end
end

-- Hàm ngắt tất cả kết nối
local function disconnectAll()
    if healthConnection then healthConnection:Disconnect() healthConnection = nil end
    if heartbeatConnection then heartbeatConnection:Disconnect() heartbeatConnection = nil end
    if stateConnection then stateConnection:Disconnect() stateConnection = nil end
end

-- Hàm bật Godmode
local function enableGodMode()
    if godmode then return end
    
    currentHumanoid = getHumanoid()
    if not currentHumanoid then
        warn("Không tìm thấy Humanoid!")
        return
    end
    
    godmode = true
    local maxHealth = currentHumanoid.MaxHealth
    
    -- Ngắt các kết nối cũ (nếu có)
    disconnectAll()
    
    -- 1. Bảo vệ máu
    healthConnection = currentHumanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if godmode and currentHumanoid and currentHumanoid.Parent then
            if currentHumanoid.Health < maxHealth then
                currentHumanoid.Health = maxHealth
            end
        end
    end)
    
    -- 2. Chống chết (Heartbeat để kiểm tra liên tục)
    heartbeatConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if godmode and currentHumanoid and currentHumanoid.Parent then
            -- Kiểm tra nếu máu <= 0 thì set lại
            if currentHumanoid.Health <= 0 then
                currentHumanoid.Health = maxHealth
            end
            -- Đảm bảo không chết do rơi/ngạt
            if currentHumanoid.Health < maxHealth then
                currentHumanoid.Health = maxHealth
            end
        end
    end)
    
    -- 3. Chống trạng thái chết
    stateConnection = currentHumanoid.StateChanged:Connect(function(oldState, newState)
        if godmode and currentHumanoid and currentHumanoid.Parent then
            if newState == Enum.HumanoidStateType.Dead then
                currentHumanoid.Health = maxHealth
                currentHumanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
    end)
    
    -- Cập nhật UI
    updateUI()
    print("✅ GODMODE đã BẬT! Bạn bất tử!")
end

-- Hàm tắt Godmode
local function disableGodMode()
    if not godmode then return end
    
    godmode = false
    
    -- Ngắt tất cả kết nối
    disconnectAll()
    
    -- Cập nhật UI
    updateUI()
    
    -- Không can thiệp vào máu nữa
    print("❌ GODMODE đã TẮT")
end

-- Xử lý nhấn nút
toggleButton.MouseButton1Click:Connect(function()
    if godmode then
        disableGodMode()
    else
        enableGodMode()
    end
end)

-- Hiệu ứng hover
toggleButton.MouseEnter:Connect(function()
    if godmode then
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    end
end)

toggleButton.MouseLeave:Connect(function()
    if godmode then
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end)

-- Xử lý khi nhân vật mới (respawn)
player.CharacterAdded:Connect(function(character)
    -- Đợi Humanoid xuất hiện
    repeat task.wait() until character:FindFirstChild("Humanoid")
    
    currentHumanoid = character.Humanoid
    
    -- Nếu godmode đang bật, kích hoạt lại
    if godmode then
        -- Tắt kết nối cũ
        disconnectAll()
        
        -- Bật lại với humanoid mới
        local maxHealth = currentHumanoid.MaxHealth
        currentHumanoid.Health = maxHealth
        
        healthConnection = currentHumanoid:GetPropertyChangedSignal("Health"):Connect(function()
            if godmode and currentHumanoid and currentHumanoid.Parent then
                if currentHumanoid.Health < maxHealth then
                    currentHumanoid.Health = maxHealth
                end
            end
        end)
        
        heartbeatConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if godmode and currentHumanoid and currentHumanoid.Parent then
                if currentHumanoid.Health <= 0 or currentHumanoid.Health < maxHealth then
                    currentHumanoid.Health = maxHealth
                end
            end
        end)
        
        stateConnection = currentHumanoid.StateChanged:Connect(function(oldState, newState)
            if godmode and currentHumanoid and currentHumanoid.Parent then
                if newState == Enum.HumanoidStateType.Dead then
                    currentHumanoid.Health = maxHealth
                    currentHumanoid:ChangeState(Enum.HumanoidStateType.Running)
                end
            end
        end)
        
        -- Cập nhật UI
        updateUI()
    end
end)

-- Khởi tạo ban đầu
local function init()
    currentHumanoid = getHumanoid()
    if currentHumanoid then
        -- Không tự bật, để người dùng tự bấm nút
        updateUI()
    end
end

-- Chạy khởi tạo
init()

print("🎮 Godmode GUI đã sẵn sàng! Nhấn nút để bất tử!")
