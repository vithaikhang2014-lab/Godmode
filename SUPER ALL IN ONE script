local function updateSuggestions()
    for _, child in pairs(suggestionList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local search = tpPlayerBox.Text:lower()
    local players = {}
    for _, p in pairs(player:GetPlayers()) do
        if p ~= player and (search == "" or p.Name:lower():find(search)) then
            table.insert(players, p)
        end
    end
    
    if #players > 0 then
        suggestionBox.Visible = true
        suggestionBox.Size = UDim2.new(1, -10, 0, math.min(#players * 30 + 10, 120))
        for _, p in pairs(players) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 28)
            btn.Position = UDim2.new(0, 5, 0, 0)
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
            btn.Text = p.Name
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.GothamSemibold
            btn.TextSize = 12
            btn.BorderSizePixel = 0
            btn.Parent = suggestionList
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 6)
            btnCorner.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                tpPlayerBox.Text = p.Name
                suggestionBox.Visible = false
            end)
        end
        suggestionList.CanvasSize = UDim2.new(0, 0, 0, suggestionLayout.AbsoluteContentSize.Y)
    else
        suggestionBox.Visible = false
    end
end

