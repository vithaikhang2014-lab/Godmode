-- ========== GODMODE ==========
local godmodeBtn = createButton("Godmode", "GODMODE", "🛡️", Color3.fromRGB(80, 40, 40))
local godmodeActive = false
local godmodeConnections = {}

local function cleanupGodmode()
    for _, conn in pairs(godmodeConnections) do
        pcall(function() conn:Disconnect() end)
    end
    godmodeConnections = {}
end

local function protectCharacter(character)
    if not character or not godmodeActive then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local maxHealth = humanoid.MaxHealth
    humanoid.Health = maxHealth
    
    local healthConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if godmodeActive and humanoid and humanoid.Parent and humanoid.Health ~= maxHealth then
            humanoid.Health = maxHealth
        end
    end)
    table.insert(godmodeConnections, healthConn)
    
    local heartbeatConn = runService.Heartbeat:Connect(function()
        if godmodeActive and humanoid and humanoid.Parent then
            if humanoid.Health <= 0 or humanoid.Health ~= maxHealth then
                humanoid.Health = maxHealth
            end
            if humanoid:GetState() == Enum.HumanoidStateType.Dead then
                humanoid.Health = maxHealth
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
    end)
    table.insert(godmodeConnections, heartbeatConn)
end

local function enableGodmode()
    if godmodeActive then return end
    godmodeActive = true
    cleanupGodmode()
    if player.Character then protectCharacter(player.Character) end
    godmodeBtn.Text = "🛡️ GODMODE ON"
    godmodeBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
end

local function disableGodmode()
    if not godmodeActive then return end
    godmodeActive = false
    cleanupGodmode()
    godmodeBtn.Text = "🛡️ GODMODE OFF"
    godmodeBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 40)
end

godmodeBtn.MouseButton1Click:Connect(function()
    if godmodeActive then disableGodmode() else enableGodmode() end
end)

