    if exp then
        -- Mở rộng: hiện scroll + các nút bên dưới
        local frameTween = tweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 200, 0, 320)
        })
        frameTween:Play()
        
        local scrollTween = tweenService:Create(mainScroll, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(1, -8, 0, 260)
        })
        scrollTween:Play()
        toggleBtn.Text = "▲"
    else
        -- Thu nhỏ: ẩn scroll, chỉ còn thanh title
        local frameTween = tweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 200, 0, 50)
        })
        frameTween:Play()
        
        local scrollTween = tweenService:Create(mainScroll, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(1, -8, 0, 0)
        })
        scrollTween:Play()
        toggleBtn.Text = "▼"
    end
end

toggleBtn.MouseButton1Click:Connect(function()
    setExpanded(not expanded)
end)

-- Cập nhật Canvas cho Scroll
local function updateCanvas()
    task.wait(0.1)
    mainScroll.CanvasSize = UDim2.new(0, 0, 0, mainLayout.AbsoluteContentSize.Y + 20)
end

mainLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
task.wait(0.2)
updateCanvas()
setExpanded(true) -- Mặc định mở rộng

