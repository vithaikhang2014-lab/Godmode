-- ========== TP ON CLICK ==========
local tpOnClickBtn = createButton("TPClick", "TP TO MOUSE", "📍", Color3.fromRGB(80, 40, 80))
local clickConn = nil

local function guiCheck(mouseX, mouseY)
    local guiPos = frame.AbsolutePosition
    local guiSize = frame.AbsoluteSize
    return (mouseX >= guiPos.X and mouseX <= guiPos.X + guiSize.X and
            mouseY >= guiPos.Y and mouseY <= guiPos.Y + guiSize.Y)
end

local function enableTPClick()
    if tpOnClick then return end
    tpOnClick = true
    clickConn = userInput.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mouse = player:GetMouse()
            if not guiCheck(mouse.X, mouse.Y) then
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp and mouse.Hit then
                    hrp.CFrame = CFrame.new(mouse.Hit.Position) + Vector3.new(0, 3, 0)
                end
            end
        end
    end)
    tpOnClickBtn.Text = "📍 TP ON (CLICK)"
    tpOnClickBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
end

local function disableTPClick()
    if not tpOnClick then return end
    tpOnClick = false
    if clickConn then clickConn:Disconnect() clickConn = nil end
    tpOnClickBtn.Text = "📍 TP TO MOUSE"
    tpOnClickBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 80)
end

tpOnClickBtn.MouseButton1Click:Connect(function()
    if tpOnClick then disableTPClick() else enableTPClick() end
end)

