local function updateSuggestions()
    for _, child in pairs(suggestionScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local search = tpPlayerBox.Text:lower()
    local players = {}
    for _, p in pairs(player:GetPlayers()) do
        if p ~= player and (search == "" or string.find(p.Name:lower(), search, 1, true)) then
            table.insert(players, p)
        end
    end
    
    if #players > 0 then
        suggestionFrame.Visible = true
        local height = math.min(#players * 30 + 10, 110)
        suggestionFrame.Size = UDim2.new(1, -8, 0, height)
        suggestionScroll.CanvasSize = UDim2.new(0, 0, 0, #players * 30)
        
        for _, p in pairs(players) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 26)
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
            btn.Text = p.Name
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.GothamSemibold
            btn.TextSize = 11
            btn.BorderSizePixel = 0
            btn.Parent = suggestionScroll
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 5)
            btnCorner.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                tpPlayerBox.Text = p.Name
                suggestionFrame.Visible = false
            end)
            
            btn.MouseEnter:Connect(function()
                btn.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
            end)
            btn.MouseLeave:Connect(function()
                btn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
            end)
        end
    else
        suggestionFrame.Visible = false
    end
end

tpPlayerBox:GetPropertyChangedSignal("Text"):Connect(updateSuggestions)
tpPlayerBox.Focused:Connect(function()
    task.wait(0.05)
    updateSuggestions()
end)
tpPlayerBox.FocusLost:Connect(function()
    task.wait(0.3)
    suggestionFrame.Visible = false
end)

tpPlayerBtn.MouseButton1Click:Connect(function()
    local targetName = tpPlayerBox.Text
    if targetName == "" then return end
    
    local found = false
    for _, p in pairs(player:GetPlayers()) do
        if string.lower(p.Name) == string.lower(targetName) then
            found = true
            local targetChar = p.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = targetChar.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                    tpPlayerBox.Text = ""
                    suggestionFrame.Visible = false
                end
            else
                tpPlayerBox.PlaceholderText = "❌ Chưa load!"
                task.wait(1)
                tpPlayerBox.PlaceholderText = "Tên người chơi..."
            end
            break
        end
    end
    if not found then
        tpPlayerBox.PlaceholderText = "❌ Không thấy!"
        task.wait(1)
        tpPlayerBox.PlaceholderText = "Tên người chơi..."
    end
end)

