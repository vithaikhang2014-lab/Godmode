-- Hàm cập nhật số lượng hiển thị
local function updateCount()
    countLabel.Text = "📂 Đã lưu: " .. #savedPositions
end

-- Hàm hiển thị thông báo góc màn hình
local function showNotification(msg)
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 300, 0, 40)
    notif.Position = UDim2.new(1, -310, 0, 10)
    notif.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    notif.BackgroundTransparency = 0.3
    notif.Text = msg
    notif.TextColor3 = Color3.fromRGB(255, 200, 100)
    notif.Font = Enum.Font.Gotham
    notif.TextSize = 14
    notif.Parent = gui
    
    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 8)
    notifCorner.Parent = notif
    
    game:GetService("Debris"):AddItem(notif, 2.5)
end

-- Sự kiện Lưu vị trí
saveBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local pos = char.HumanoidRootPart.CFrame
        table.insert(savedPositions, pos)
        updateCount()
        showNotification("✅ Đã lưu vị trí #" .. #savedPositions)
    else
        showNotification("⚠️ Không tìm thấy nhân vật!")
    end
end)

-- Sự kiện Dịch chuyển
teleportBtn.MouseButton1Click:Connect(function()
    if #savedPositions == 0 then
        showNotification("❌ Vui lòng lưu vị trí ở góc màn hình!")
        return
    end
    
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        -- Dịch chuyển đến vị trí lưu gần nhất (theo thứ tự mới nhất)
        local targetPos = savedPositions[#savedPositions]
        char.HumanoidRootPart.CFrame = targetPos
        showNotification("✨ Đã dịch chuyển đến vị trí #" .. #savedPositions)
    else
        showNotification("⚠️ Không thể dịch chuyển lúc này!")
    end
end)

-- Sự kiện Reset
resetBtn.MouseButton1Click:Connect(function()
    if #savedPositions > 0 then
        savedPositions = {}
        updateCount()
        showNotification("🗑️ Đã xóa tất cả " .. (#savedPositions) .. " vị trí")
    else
        showNotification("📭 Không có vị trí nào để xóa!")
    end
end)

-- Ban đầu cập nhật
updateCount()
